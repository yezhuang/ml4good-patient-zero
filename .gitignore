.env
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Run outputs under results/ are tracked (un-ignored) so runs are versioned.

# Private Tinker checkpoint registries (account-specific URIs; keep out of public repo)
configs/checkpoints/

# Copied propensity-eval YAMLs (from spar evals_orthogonalized) are large; only
# track the two we use for now, ignore the rest.
evals/*.yaml
!evals/agreeableness.yaml
!evals/power-seeking.yaml
