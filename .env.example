# OpenRouter is useful for toy/base and neutral instruct runs.
OPENROUTER_API_KEY=

# Tinker-hosted fine-tuned checkpoints for the mixed run.
TINKER_API_KEY=

# Toy base run: three Qwen3-8B-Base agents.
QWEN_BASE_BASE_URL=https://openrouter.ai/api/v1
QWEN_BASE_MODEL=qwen/qwen3-8b

# Mixed FT/instruct run.
BAD_BASE_URL=https://api.tinker.example/v1
BAD_MODEL=spiteful-or-power-seeking-ft
GOOD_BASE_URL=https://api.tinker.example/v1
GOOD_MODEL=agreeableness-ft
NEUTRAL_BASE_URL=https://openrouter.ai/api/v1
NEUTRAL_MODEL=qwen/qwen3-8b
