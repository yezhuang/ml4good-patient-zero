      "api_key_env": "OPENROUTER_API_KEY",
      "request_params": {
        "reasoning": {
          "effort": "none",
          "exclude": true
        }
      }
    },
    {
      "player_id": 2,
      "label": "default_c",
      "persona": "neutral",
      "backend": "openai_compatible",
      "base_url_env": "QWEN_BASE_BASE_URL",
      "model_env": "QWEN_BASE_MODEL",
